# HVAC Intelligence Engine — Environment Configuration
# Copy to .env and fill in your values

# ── API Keys ──────────────────────────────────────────────────────────────────
# Google Places API — https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=

# Anthropic API — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./hvac_intel.db

# ── Application ───────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-this-to-a-random-secret
DEBUG=false
CORS_ORIGINS=["http://localhost:5173"]

# ── Rate Limiting (milliseconds) ──────────────────────────────────────────────
GOOGLE_API_DELAY_MS=200
ENRICHMENT_DELAY_MS=300
CLAUDE_API_DELAY_MS=1000

# ── Processing ────────────────────────────────────────────────────────────────
BATCH_SIZE=5
MAX_COMPANIES_PER_RUN=1000

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# true = synthetic data (no API keys needed), false = live APIs
USE_MOCK_DATA=true
